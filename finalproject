class Database:

    def __init__(self):
        # __init__ — це спеціальний метод який запускається
        # автоматично коли ми створюємо об'єкт цього класу
        # тут ми підключаємось до бази даних

        # sqlite3.connect() — відкриває файл бази даних
        # якщо файл не існує — він створюється автоматично
        self.зєднання = sqlite3.connect("мої_сайти.db")

        # cursor() — це як "ручка" якою ми пишемо запити до бази
        # без курсора не можна виконувати SQL-команди
        self.курсор = self.зєднання.cursor()

        # відразу створюємо таблицю (якщо її ще нема)
        self.створити_таблицю()
        print("✅ База даних підключена!")

    def створити_таблицю(self):
        # execute() — виконує SQL-команду
        # SQL — це мова для роботи з базами даних
        # CREATE TABLE IF NOT EXISTS — створити таблицю якщо вона ще не існує
        # це важливо щоб програма не падала при повторному запуску
        self.курсор.execute("""
            CREATE TABLE IF NOT EXISTS сайти (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                адреса TEXT NOT NULL,
                ключове_слово TEXT,
                кількість_знайдень INTEGER DEFAULT 0
            )
        """)
        # commit() — зберігає зміни в файл бази даних
        # без commit() зміни будуть тільки в памяті і зникнуть після закриття
        self.зєднання.commit()

    def додати_сайт(self, адреса, ключове_слово=""):
        # спочатку перевіряємо чи такий сайт вже є в базі
        # SELECT * — вибрати всі стовпці
        # WHERE адреса = ? — знайти рядок де адреса = нашому значенню
        # ? — це місце-заповнювач, захищає від SQL-ін'єкцій (атак на базу)
        self.курсор.execute("SELECT * FROM сайти WHERE адреса = ?", (адреса,))

        # fetchone() — повертає один знайдений рядок або None якщо нічого не знайшло
        якщо_є = self.курсор.fetchone()

        if якщо_є:
            print(f"⚠️  Сайт '{адреса}' вже є в базі!")
        else:
            # INSERT INTO — додати новий рядок в таблицю
            # VALUES (?, ?) — значення які ми вставляємо (знову ? для безпеки)
            self.курсор.execute(
                "INSERT INTO сайти (адреса, ключове_слово) VALUES (?, ?)",
                (адреса, ключове_слово)
            )
            self.зєднання.commit()
            print(f"✅ Сайт '{адреса}' додано!")

    def отримати_всі_сайти(self):
        # SELECT * FROM сайти — отримати всі рядки з таблиці
        self.курсор.execute("SELECT * FROM сайти")

        # fetchall() — повертає список ВСІХ знайдених рядків
        # (на відміну від fetchone() який повертає тільки один)
        return self.курсор.fetchall()

    def видалити_сайт(self, адреса):
        # DELETE FROM — видалити рядки з таблиці
        # WHERE адреса = ? — тільки ті де адреса співпадає
        self.курсор.execute("DELETE FROM сайти WHERE адреса = ?", (адреса,))
        self.зєднання.commit()
        print(f"🗑️  Сайт '{адреса}' видалено!")

    def оновити_кількість(self, адреса, кількість):
        # UPDATE — оновити існуючий рядок в таблиці
        # SET кількість_знайдень = ? — встановити нове значення в цьому стовпці
        self.курсор.execute(
            "UPDATE сайти SET кількість_знайдень = ? WHERE адреса = ?",
            (кількість, адреса)
        )
        self.зєднання.commit()

    def очистити_базу(self):
        # DELETE FROM без WHERE — видаляє ВСІ рядки з таблиці
        # таблиця залишається але стає порожньою
        self.курсор.execute("DELETE FROM сайти")
        self.зєднання.commit()
        print("🧹 Базу очищено!")

    def закрити(self):
        # close() — закриваємо з'єднання з базою коли програма завершується
        # завжди треба закривати з'єднання щоб не було проблем з файлом
        self.зєднання.close()

class Parser:

    def __init__(self):
        # User-Agent — це рядок який браузер надсилає сайту
        # щоб сказати "привіт я Firefox/Chrome/тощо"
        # ми підробляємо його щоб сайти не блокували нас як бота
        # бо деякі сайти не відповідають програмам без цього заголовку
        self.заголовки = {
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
        }

    def отримати_текст(self, url):
        # url — адреса сторінки яку хочемо завантажити
        # наприклад: "https://uk.wikipedia.org/wiki/Python"

        # try/except — конструкція для обробки помилок
        # якщо щось піде не так — програма не зупиниться а виконає except-блок
        try:
            # requests.get() — надсилає GET-запит на сервер
            # GET — тип запиту "дай мені цю сторінку"
            # headers — наші підроблені заголовки браузера
            # timeout=10 — якщо сайт не відповідає 10 секунд — припиняємо чекати
            відповідь = requests.get(url, headers=self.заголовки, timeout=10)

            # raise_for_status() — якщо сервер повернув помилку (404, 500 тощо)
            # ця функція автоматично кидає виключення щоб ми знали про помилку
            відповідь.raise_for_status()

            # BeautifulSoup() — "розбирає" HTML-код сторінки
            # відповідь.text — HTML-код сторінки у вигляді тексту
            # "html.parser" — вбудований в Python інструмент для читання HTML
            суп = BeautifulSoup(відповідь.text, "html.parser")

            # прибираємо теги <script> і <style> з HTML
            # <script> — це JavaScript-код (програмний, не текст для читання)
            # <style> — це CSS-стилі (кольори, шрифти — нам не потрібно)
            # decompose() — повністю видаляє тег з дерева HTML
            for тег in суп(["script", "style"]):
                тег.decompose()

            # get_text() — витягує тільки текст без HTML-тегів
            # separator=" " — розділяє слова пробілом (щоб не зливалися)
            текст = суп.get_text(separator=" ")

            # прибираємо зайві пробіли, переноси рядків тощо
            # split() без аргументів ділить по БУДЬ-яких пробілах/переносах
            # " ".join() — збирає назад в один рядок через пробіл
            текст = " ".join(текст.split())
            return текст

        # ConnectionError — помилка коли немає інтернету або сайт не існує
        except requests.exceptions.ConnectionError:
            print(f"❌ Не можу підключитись до {url}")
            return None

        # Timeout — помилка коли сайт занадто довго не відповідає
        except requests.exceptions.Timeout:
            print(f"⏱️  Час очікування вийшов для {url}")
            return None

        # Exception — ловимо будь-яку іншу несподівану помилку
        except Exception as помилка:
            print(f"❌ Помилка: {помилка}")
            return None

    def порахувати_слово(self, текст, слово):
        # перевіряємо чи є взагалі текст (якщо сайт не завантажився — None)
        if текст is None:
            return 0

        # lower() — переводить рядок в нижній регістр
        # це потрібно щоб "Python", "python", "PYTHON" вважались однаковим словом
        текст_маленький = текст.lower()
        слово_маленьке = слово.lower()

        # count() — рахує скільки разів підрядок зустрічається в рядку
        # повертає число (0 якщо не знайдено жодного разу)
        кількість = текст_маленький.count(слово_маленьке)
        return кількість



class Interface:

    def __init__(self):
        # створюємо об'єкти двох інших класів
        # тепер self.bd і self.parser доступні у всіх методах цього класу
        self.bd = DataBase()
        self.parser = Parser()
        print("\n🌐 Вітаю в моїй програмі для пошуку по сайтах!")
        print("=" * 50)

    def показати_меню(self):
        # просто виводимо список варіантів
        # print() — виводить текст в консоль
        print("\n📋 ЩО ХОЧЕШ ЗРОБИТИ?")
        print("1 - Додати сайт до списку")
        print("2 - Показати всі сайти")
        print("3 - Шукати слово на всіх сайтах")
        print("4 - Видалити сайт")
        print("5 - Очистити базу")
        print("6 - Вийти")
        print("-" * 30)

    def додати_сайт(self):
        # input() — зупиняє програму і чекає поки користувач щось введе
        # strip() — прибирає пробіли на початку і в кінці введеного тексту
        адреса = input("Введи адресу сайту (наприклад https://example.com): ").strip()

        # startswith() — перевіряє чи рядок починається з певних символів
        # якщо користувач не написав "http" — додаємо самі
        if not адреса.startswith("http"):
            адреса = "https://" + адреса

        ключове = input("Ключове слово для цього сайту (або Enter щоб пропустити): ").strip()

        # викликаємо метод бази даних щоб зберегти сайт
        self.бд.додати_сайт(адреса, ключове)

    def показати_сайти(self):
        # отримуємо список всіх сайтів з бази
        сайти = self.бд.отримати_всі_сайти()

        # якщо список порожній — повідомляємо і виходимо з методу
        if not сайти:
            print("😅 Список сайтів порожній! Спочатку додай сайти.")
            return  # return без значення просто виходить з функції

        # len() — повертає кількість елементів у списку
        # f"..." — f-рядок дозволяє вставляти змінні прямо в текст через {}
        print(f"\n📌 Всі сайти в базі ({len(сайти)} шт):")
        print("-" * 60)

        # for ... in — цикл який перебирає всі елементи списку по одному
        for сайт in сайти:
            # кожен сайт — це кортеж (id, адреса, ключове_слово, кількість)
            # розпаковуємо його в окремі змінні
            id_, адреса, ключове, кількість = сайт
            print(f"  {id_}. {адреса}")
            print(f"     🔑 Ключове слово: {ключове or 'не задано'}")
            # "або" через or — якщо ключове порожнє ("") — виводить 'не задано'
            print(f"     🔢 Кількість знайдень: {кількість}")
        print("-" * 60)

    def шукати_на_сайтах(self):
        слово = input("Введи слово для пошуку: ").strip()

        # якщо рядок порожній — not "" повертає True
        if not слово:
            print("⚠️  Ти не ввів слово!")
            return

        сайти = self.бд.отримати_всі_сайти()
        if not сайти:
            print("😅 Немає сайтів для пошуку! Спочатку додай.")
            return

        print(f"\n🔍 Шукаю '{слово}' на всіх сайтах...")
        print("-" * 60)

        # порожній список куди будемо складати результати
        результати = []

        for сайт in сайти:
            id_, адреса, ключове, _ = сайт
            # _ — домовленість що ця змінна нам не потрібна (ігноруємо її)

            print(f"⏳ Обробляю {адреса}...")

            # завантажуємо текст сторінки через клас Парсер
            текст = self.парсер.отримати_текст(адреса)

            # рахуємо скільки разів зустрічається слово
            кількість = self.парсер.порахувати_слово(текст, слово)

            # зберігаємо результат в базу даних
            self.бд.оновити_кількість(адреса, кількість)

            # append() — додає елемент в кінець списку
            # додаємо словник з результатом для цього сайту
            результати.append({
                "сайт": адреса,
                "кількість": кількість
            })

            print(f"   ✔️  Знайдено '{слово}': {кількість} разів")

        # sort() — сортує список
        # key=lambda x: x["кількість"] — сортуємо за полем "кількість"
        # lambda — мала анонімна функція, створюється прямо тут без def
        # reverse=True — сортуємо від БІЛЬШОГО до меншого
        результати.sort(key=lambda x: x["кількість"], reverse=True)

        print("\n🏆 РЕЗУЛЬТАТИ (від кращого до гіршого):")
        print("=" * 60)

        # enumerate() — додає лічильник до циклу
        # i починається з 1 (бо написали enumerate(..., 1))
        for i, рез in enumerate(результати, 1):
            # min() — повертає менше з двох чисел
            # обмежуємо кількість зірок до 5 щоб не було 1000 зірок
            зірки = "⭐" * min(рез["кількість"], 5)
            print(f"  {i}. {рез['сайт']}")
            print(f"     Знайдено: {рез['кількість']} разів {зірки}")
        print("=" * 60)

        # перевіряємо чи взагалі щось знайшли
        if результати and результати[0]["кількість"] > 0:
            print(f"\n🥇 Найкращий результат: {результати[0]['сайт']}")
        else:
            print(f"\n😔 Слово '{слово}' не знайдено на жодному сайті")

    def видалити_сайт(self):
        адреса = input("Введи адресу сайту для видалення: ").strip()
        self.бд.видалити_сайт(адреса)

    def запустити(self):
        # while True — безкінечний цикл, програма крутиться поки не зупинимо
        # виходимо з нього тільки через break (при виборі "6 - Вийти")
        while True:
            self.показати_меню()

            # читаємо що ввів користувач
            вибір = input("Твій вибір: ").strip()

            # if/elif/else — перевіряємо що вибрав користувач
            # і викликаємо відповідний метод
            if вибір == "1":
                self.додати_сайт()
            elif вибір == "2":
                self.показати_сайти()
            elif вибір == "3":
                self.шукати_на_сайтах()
            elif вибір == "4":
                self.видалити_сайт()
            elif вибір == "5":
                підтвердження = input("Точно очистити всю базу? (так/ні): ")
                # lower() — щоб "Так", "ТАК", "так" — всі спрацьовували
                if підтвердження.lower() == "так":
                    self.бд.очистити_базу()
            elif вибір == "6":
                print("\n👋 До побачення!")
                self.db.закрити()
                break  # break — виходить з циклу while True і програма закривається
            else:
                # якщо ввели щось інше — просимо ввести ще раз
                print("❓ Не розумію, введи число від 1 до 6")


